# Application
APP_ENV=dev
HTTP_PORT=8080

# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/ai_product_assistant?sslmode=disable

# LLM Provider (OpenAI-compatible)
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=sk-your-api-key-here
LLM_MODEL=gpt-4

# LLM Settings (optional)
LLM_TIMEOUT_SEC=15
LLM_MAX_RETRIES=2
LLM_RETRY_BASE_DELAY_MS=200

# HTTP Settings (optional)
HTTP_READ_TIMEOUT_SEC=10
HTTP_WRITE_TIMEOUT_SEC=10
HTTP_IDLE_TIMEOUT_SEC=60
HTTP_SHUTDOWN_TIMEOUT_SEC=10
DB_PING_TIMEOUT_SEC=5

# Rate Limiting
HTTP_RATE_LIMIT_RPM=20
HTTP_RATE_LIMIT_WINDOW_SEC=60

